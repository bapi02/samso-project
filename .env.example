# Copy this file to `.env.local` and fill in the values from the Firebase
# Console (Project Settings → General → Your apps → Web app config).
#
# The web-side API key is a *public* identifier and not a secret. Database
# rules + the slot/results schema are the actual security layer.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# These have working defaults baked into src/shared/firebase.js for the
# samso-b202f project, but you can override them here.
# VITE_FIREBASE_AUTH_DOMAIN=samso-b202f.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=samso-b202f
# VITE_FIREBASE_STORAGE_BUCKET=samso-b202f.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=941051169140
